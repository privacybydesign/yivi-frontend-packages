{
  "name": "@privacybydesign/yivi-client",
  "version": "1.0.0-beta.1",
  "description": "A plugin to allow your Yivi flows to communicate with a server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "license": "SEE LICENSE IN REPOSITORY",
  "dependencies": {
    "deepmerge": "^4.2.2",
    "eventsource": "^1.0.7"
  },
  "peerDependencies": {
    "@privacybydesign/yivi-core": "^1.0.0-beta.1"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/privacybydesign/yivi-frontend-packages",
    "directory": "plugins/yivi-client"
  }
}
