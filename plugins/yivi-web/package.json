{
  "name": "@privacybydesign/yivi-web",
  "version": "1.0.0-beta.1",
  "description": "A front-end to Yivi flows for in the web browser",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "license": "SEE LICENSE IN REPOSITORY",
  "dependencies": {
    "deepmerge": "^4.2.2",
    "qrcode": "^1.4.2"
  },
  "peerDependencies": {
    "@privacybydesign/yivi-core": "^1.0.0-beta.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/privacybydesign/yivi-frontend-packages",
    "directory": "plugins/yivi-web"
  }
}
