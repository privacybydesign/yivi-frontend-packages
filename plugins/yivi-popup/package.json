{
  "name": "@privacybydesign/yivi-popup",
  "version": "0.2.1",
  "description": "A front-end plugin to show the Yivi form in a popup",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "license": "SEE LICENSE IN REPOSITORY",
  "dependencies": {
    "deepmerge": "^4.2.2"
  },
  "peerDependencies": {
    "@privacybydesign/yivi-core": "^0.2.1",
    "@privacybydesign/yivi-web": "^0.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/privacybydesign/yivi-frontend-packages",
    "directory": "plugins/yivi-popup"
  }
}
